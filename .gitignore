# ==============================================================================
# financial-cashflow-agent — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# CRITICAL — Secrets (never commit these)
# ------------------------------------------------------------------------------
.env

# ------------------------------------------------------------------------------
# Virtual environment
# ------------------------------------------------------------------------------
venv/
.venv/
env/

# ------------------------------------------------------------------------------
# Python cache
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ------------------------------------------------------------------------------
# Generated data (too large for git, regenerated by scripts)
# ------------------------------------------------------------------------------
data/db/*.db
data/vector_store/*.faiss
data/vector_store/*.pkl
data/vector_store/*.index

# PDFs in data/ are generated by our scripts — don't commit them
# (If you add real PDFs you want to track, remove this line)
data/pdfs/

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------------------------
# Distribution / build
# ------------------------------------------------------------------------------
dist/
build/
*.egg-info/
.eggs/

# ------------------------------------------------------------------------------
# IDE and editor
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# OS junk
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# Jupyter (if you ever explore data interactively)
# ------------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

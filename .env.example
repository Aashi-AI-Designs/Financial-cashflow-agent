# ==============================================================================
# financial-cashflow-agent — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# NEVER commit your .env file. It is listed in .gitignore.
# ==============================================================================

# ------------------------------------------------------------------------------
# OpenAI — Required
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# Model used for chat / agent reasoning
OPENAI_CHAT_MODEL=gpt-4o-mini

# Model used for generating embeddings (for RAG)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Maximum tokens the LLM generates per response
OPENAI_MAX_TOKENS=2048

# ------------------------------------------------------------------------------
# Database — SQLite
# ------------------------------------------------------------------------------
# Path relative to project root
DB_PATH=data/db/runway.db

# ------------------------------------------------------------------------------
# Vector Store — FAISS
# ------------------------------------------------------------------------------
# Directory where FAISS index files are saved
VECTOR_STORE_PATH=data/vector_store/

# Number of document chunks returned per RAG search
RAG_TOP_K=5

# How large each document chunk is (in characters)
CHUNK_SIZE=1000

# How much chunks overlap (helps preserve context at chunk boundaries)
CHUNK_OVERLAP=200

# ------------------------------------------------------------------------------
# Agent
# ------------------------------------------------------------------------------
# How many ReAct loop iterations the agent is allowed before it stops
AGENT_MAX_ITERATIONS=10

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Set to true to also write logs to a file
LOG_TO_FILE=false

# Log file path (only used if LOG_TO_FILE=true)
LOG_FILE_PATH=logs/agent.log
